<script is:inline define:vars={{ apiBase }}>
  (function() {
    var API_BASE = apiBase;
    var STORAGE_KEY = 'fhd_dash_auth';

    function unlock() {
      document.getElementById('auth-gate').style.display = 'none';
      document.getElementById('dashboard-root').style.display = '';
      window.dispatchEvent(new CustomEvent('dashboard-unlocked'));
    }

    var stored = localStorage.getItem(STORAGE_KEY) || sessionStorage.getItem(STORAGE_KEY);
    if (stored === 'authed') {
      unlock();
    }

    document.getElementById('auth-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var pw = document.getElementById('auth-password').value;
      var errorEl = document.getElementById('auth-error');
      errorEl.hidden = true;
      try {
        var res = await fetch(API_BASE + '/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pw })
        });
        var data = await res.json();
        if (res.ok && data.ok) {
          if (document.getElementById('auth-remember').checked) {
            localStorage.setItem(STORAGE_KEY, 'authed');
          }
          sessionStorage.setItem(STORAGE_KEY, 'authed');
          unlock();
        } else {
          errorEl.hidden = false;
          document.getElementById('auth-password').value = '';
          document.getElementById('auth-password').focus();
        }
      } catch (err) {
        errorEl.hidden = false;
        document.getElementById('auth-password').value = '';
        document.getElementById('auth-password').focus();
      }
    });
  })();
</script>

<script>
  import { initTabNavigation } from '../scripts/tab-navigation.js';
  import { initMonthSelector, refreshMonthButtons, activateLatestMonth } from '../scripts/month-selector.js';
  import { initCharts } from '../scripts/charts.js';
  import { initCampaignToggle } from '../scripts/campaign-toggle.js';
  import { initKpiAnimations } from '../scripts/kpi-animations.js';
  import { fetchMonths, fetchLastUpdated } from '../scripts/data.js';
  import { initInfomaterial } from '../scripts/fetching/manual/infomaterial.js';
  import { initContractOverview } from '../scripts/fetching/manual/contract-overview.js';
  import { initStudycheck } from '../scripts/fetching/manual/studycheck.js';
  import { initLinkedin } from '../scripts/fetching/manual/linkedin.js';
  import { initTiktok } from '../scripts/fetching/manual/tiktok.js';

  let dashboardInitialized = false;

  async function initDashboard() {
    if (dashboardInitialized) return;
    dashboardInitialized = true;

    initTabNavigation();
    initMonthSelector();
    initCampaignToggle();
    initKpiAnimations();
    initInfomaterial();
    initContractOverview();
    initStudycheck();
    initLinkedin();
    initTiktok();

    const loadingEl = document.getElementById('loading-state');

    try {
      await Promise.all([fetchMonths(), fetchLastUpdated()]);
      if (loadingEl) loadingEl.classList.remove('active');
      refreshMonthButtons();
      activateLatestMonth();
      setTimeout(() => { initCharts(); }, 200);
    } catch (err: unknown) {
      console.error('Failed to load dashboard data:', err);
      if (loadingEl) loadingEl.classList.remove('active');
      refreshMonthButtons();
      activateLatestMonth();
      setTimeout(() => { initCharts(); }, 200);
    }
  }

  const root = document.getElementById('dashboard-root');
  const alreadyVisible = root && root.style.display !== 'none';

  if (alreadyVisible) {
    initDashboard();
  } else {
    window.addEventListener('dashboard-unlocked', () => initDashboard(), { once: true });
  }
</script>
