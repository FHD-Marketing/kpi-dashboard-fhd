---
import '../styles/global.css';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>FHD Performance Dashboard 2026</title>
  <meta name="description" content="KPI-Dashboard der Fachhochschule Dresden – Alle Kommunikationskanäle auf einen Blick." />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js" is:inline></script>
</head>
<body>
<div class="dashboard">

  <header class="dashboard-header">
    <div class="header-left">
      <div class="header-label">Performance Dashboard 2026</div>
      <h1>Fachhochschule Dresden</h1>
      <div class="header-subtitle">Google Ads · Meta Ads · Jahresübersicht</div>
    </div>
  </header>

  <nav class="year-selector">
    <button class="year-btn active" data-year="2026">2026</button>
    <button class="year-btn" data-year="2027">2027</button>
    <button class="year-btn" data-year="2028">2028</button>
    <button class="year-btn" data-year="2029">2029</button>
    <button class="year-btn" data-year="2030">2030</button>
  </nav>

  <nav class="month-selector">
    <button class="month-btn disabled" data-month="jan"><span class="month-label">Jan</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="feb"><span class="month-label">Feb</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="mar"><span class="month-label">Mär</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="apr"><span class="month-label">Apr</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="mai"><span class="month-label">Mai</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="jun"><span class="month-label">Jun</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="jul"><span class="month-label">Jul</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="aug"><span class="month-label">Aug</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="sep"><span class="month-label">Sep</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="oct"><span class="month-label">Okt</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="nov"><span class="month-label">Nov</span><span class="month-spend"></span></button>
    <button class="month-btn disabled" data-month="dec"><span class="month-label">Dez</span><span class="month-spend"></span></button>
  </nav>

  <div class="tab-navigation-wrapper">
    <nav class="tab-navigation" data-row="echtzeit">
      <span class="tab-row-label">Echtzeit</span>
      <button class="tab-btn disabled" data-tab="uebersicht"><span class="tab-icon">📊</span> Übersicht</button>
      <button class="tab-btn disabled" data-tab="google"><span class="tab-icon">🔵</span> Google Ads</button>
      <button class="tab-btn disabled" data-tab="meta"><span class="tab-icon">🟦</span> Meta Ads</button>
      <button class="tab-btn disabled" data-tab="instagram"><span class="tab-icon">📸</span> Instagram</button>
      <button class="tab-btn disabled" data-tab="youtube"><span class="tab-icon">▶️</span> YouTube</button>
      <button class="tab-btn disabled" data-tab="tiktok"><span class="tab-icon">🎵</span> TikTok</button>
      <button class="tab-btn disabled" data-tab="linkedin"><span class="tab-icon">💼</span> LinkedIn</button>
      <button class="tab-btn disabled" data-tab="mailchimp"><span class="tab-icon">📧</span> Mailchimp</button>
    </nav>
    <nav class="tab-navigation" data-row="manuell">
      <span class="tab-row-label">Manuell</span>
      <button class="tab-btn disabled" data-tab="studycheck"><span class="tab-icon">⭐</span> StudyCheck</button>
      <button class="tab-btn disabled" data-tab="infomaterial"><span class="tab-icon">📥</span> Infomaterialanfragen</button>
    </nav>
  </div>

  <section id="loading-state" class="tab-content active">
    <div class="loading-state">
      <div class="loading-spinner"></div>
      <p>Daten werden geladen…</p>
    </div>
  </section>

  <section id="tab-empty" class="tab-content">
    <div class="empty-state">
      <h2>Keine API-Daten für diesen Monat</h2>
      <p>Es sind noch keine Echtzeit-Daten für diesen Monat verfügbar. Die manuellen Tabs (StudyCheck, Infomaterial) können trotzdem genutzt werden.</p>
    </div>
  </section>

  <section id="tab-uebersicht" class="tab-content">
    <h2 class="section-title" id="overview-title"><span class="title-icon">📊</span> Übersicht</h2>
    <p class="section-subtitle">Alle Kanäle auf einen Blick</p>

    <div class="kpi-grid cols-3">
      <div class="kpi-card" data-kpi="overview-adSpend">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">🔥</span> AD SPEND</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
      <div class="kpi-card" data-kpi="overview-klicks">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">👆</span> KLICKS</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
      <div class="kpi-card" data-kpi="overview-conversions">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">🎯</span> CONVERSIONS / LEADS</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
    </div>

    <div class="kpi-grid cols-4">
      <div class="kpi-card" data-kpi="overview-impressionen">
        <div class="kpi-card-header">
          <span class="kpi-card-label">IMPRESSIONEN</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
      <div class="kpi-card" data-kpi="overview-reichweite">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">👁️</span> REICHWEITE</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
      <div class="kpi-card" data-kpi="overview-cpc">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">💰</span> Ø CPC</span>
          <span class="kpi-trend"></span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
      <div class="kpi-card" data-kpi="overview-ctr">
        <div class="kpi-card-header">
          <span class="kpi-card-label"><span class="kpi-icon">📊</span> CTR</span>
        </div>
        <div class="kpi-value">—</div>
        <div class="kpi-detail">—</div>
      </div>
    </div>

    <div class="charts-grid wide-left">
      <div class="chart-card">
        <div class="chart-card-header">
          <span class="chart-card-title" id="daily-spend-title">Tagesverlauf Spend</span>
          <div class="chart-toggle"><button class="active">Google</button><button>Meta</button></div>
        </div>
        <div class="chart-wrapper" style="height:220px"><canvas id="daily-spend-chart"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-card-header"><span class="chart-card-title">Budget-Split</span></div>
        <div class="chart-wrapper" style="height:180px"><canvas id="budget-split-chart"></canvas></div>
        <div class="chart-legend" id="budget-split-legend">
          <div class="legend-item"><span class="legend-dot" style="background:#4285f4"></span> Google Ads</div>
          <div class="legend-item"><span class="legend-dot" style="background:#0668e1"></span> Meta Ads</div>
        </div>
      </div>
    </div>

    <h3 class="section-title mb-md" id="budget-plan-title"><span class="title-icon">🟥</span> Budgetplan vs. Ist</h3>
    <div class="budget-grid">
      <div class="budget-card" data-budget="gesamt">
        <div class="budget-card-header"><span class="budget-card-title">Gesamt</span><span class="budget-badge"></span></div>
        <div class="budget-values"><div class="budget-plan">Plan<span>—</span></div><div class="budget-actual">Ist<span>—</span></div></div>
        <div class="budget-bar"><div class="budget-bar-fill" style="width:0%"></div></div>
        <div class="budget-footer"><span></span><span class="budget-diff"></span></div>
      </div>
      <div class="budget-card" data-budget="google">
        <div class="budget-card-header"><span class="budget-card-title">Google Ads</span><span class="budget-badge"></span></div>
        <div class="budget-values"><div class="budget-plan">Plan<span>—</span></div><div class="budget-actual">Ist<span>—</span></div></div>
        <div class="budget-bar"><div class="budget-bar-fill" style="width:0%"></div></div>
        <div class="budget-footer"><span></span><span class="budget-diff"></span></div>
      </div>
      <div class="budget-card" data-budget="meta">
        <div class="budget-card-header"><span class="budget-card-title">Meta Ads</span><span class="budget-badge"></span></div>
        <div class="budget-values"><div class="budget-plan">Plan<span>—</span></div><div class="budget-actual">Ist<span>—</span></div></div>
        <div class="budget-bar"><div class="budget-bar-fill" style="width:0%"></div></div>
        <div class="budget-footer"><span></span><span class="budget-diff"></span></div>
      </div>
    </div>

    <h3 class="section-title mb-md" id="ytd-trends-title"><span class="title-icon">📈</span> Year-to-Date Trends</h3>
    <p class="section-subtitle">Monatlicher Vergleich</p>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Monatliche Ausgaben — Plan vs. Ist</span></div><div class="chart-wrapper" style="height:250px"><canvas id="ytd-ausgaben-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Conversions / Leads</span></div><div class="chart-wrapper" style="height:250px"><canvas id="ytd-conversions-chart"></canvas></div></div>
    </div>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">CPC-Entwicklung</span></div><div class="chart-wrapper" style="height:250px"><canvas id="ytd-cpc-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Impressionen pro Monat</span></div><div class="chart-wrapper" style="height:250px"><canvas id="ytd-impressionen-chart"></canvas></div></div>
    </div>
    <div class="chart-card">
      <div class="chart-card-header"><span class="chart-card-title">Monatsvergleich — KPIs</span></div>
      <div class="data-table-wrapper"><table class="data-table" id="ytd-comparison-table"><thead><tr><th>Monat</th><th>Plan</th><th>Ist</th><th>Δ Budget</th><th>Klicks</th><th>Conv./Leads</th><th>Ø CPC</th></tr></thead><tbody></tbody></table></div>
    </div>
  </section>

  <section id="tab-google" class="tab-content">
    <h2 class="section-title" id="google-title"><span class="title-icon">🔵</span> Google Ads Kampagnen</h2>
    <p class="section-subtitle">Klicke auf eine Kampagne, um Details zu sehen</p>

    <div class="kpi-grid cols-4 channel-google">
      <div class="kpi-card" data-kpi="google-spend">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">🔥</span> GOOGLE SPEND</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="google-klicks">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">👆</span> KLICKS</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="google-conversions">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">🎯</span> CONVERSIONS</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="google-impressionen">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">👁️</span> IMPRESSIONEN</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
    </div>

    <div class="chart-card mb-xl">
      <div class="chart-card-header"><span class="chart-card-title">Spend nach Kampagne</span></div>
      <div class="horiz-bar-chart" id="google-spend-bars"></div>
    </div>

    <div id="google-campaign-cards"></div>
  </section>

  <section id="tab-meta" class="tab-content">
    <h2 class="section-title" id="meta-title"><span class="title-icon">🟦</span> Meta Kampagnen</h2>
    <p class="section-subtitle">Klicke auf eine Kampagne, um die Anzeigengruppen zu sehen</p>

    <div class="kpi-grid cols-4 channel-meta">
      <div class="kpi-card" data-kpi="meta-spend">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">🔥</span> META SPEND</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="meta-linkKlicks">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">👆</span> LINK-KLICKS</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="meta-leads">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">🎯</span> LEADS</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
      <div class="kpi-card" data-kpi="meta-reichweite">
        <div class="kpi-card-header"><span class="kpi-card-label"><span class="kpi-icon">👁️</span> REICHWEITE</span><span class="kpi-trend"></span></div>
        <div class="kpi-value">—</div>
      </div>
    </div>

    <div id="meta-campaign-sections"></div>
  </section>

  <section id="tab-instagram" class="tab-content">
    <h2 class="section-title" id="instagram-title"><span class="title-icon">📸</span> Instagram</h2>
    <p class="section-subtitle">Organische Performance</p>
    <div class="kpi-grid cols-4 channel-instagram">
      <div class="kpi-card" data-kpi="instagram-follower"><div class="kpi-card-header"><span class="kpi-card-label">FOLLOWER</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="instagram-engagementRate"><div class="kpi-card-header"><span class="kpi-card-label">ENGAGEMENT RATE</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="instagram-reichweite"><div class="kpi-card-header"><span class="kpi-card-label">REICHWEITE</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="instagram-impressionen"><div class="kpi-card-header"><span class="kpi-card-label">IMPRESSIONEN</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
    </div>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Follower-Wachstum</span></div><div class="chart-wrapper" style="height:220px"><canvas id="instagram-follower-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Top Posts (Reichweite)</span></div><div class="chart-wrapper" style="height:220px"><canvas id="instagram-top-posts-chart"></canvas></div></div>
    </div>
  </section>

  <section id="tab-youtube" class="tab-content">
    <h2 class="section-title" id="youtube-title"><span class="title-icon">▶️</span> YouTube</h2>
    <p class="section-subtitle">Kanal-Performance</p>
    <div class="kpi-grid cols-4 channel-youtube">
      <div class="kpi-card" data-kpi="youtube-views"><div class="kpi-card-header"><span class="kpi-card-label">VIEWS</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="youtube-subscribers"><div class="kpi-card-header"><span class="kpi-card-label">ABONNENTEN</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="youtube-watchTime"><div class="kpi-card-header"><span class="kpi-card-label">WATCH TIME</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
      <div class="kpi-card" data-kpi="youtube-ctr"><div class="kpi-card-header"><span class="kpi-card-label">CTR</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div><div class="kpi-detail"></div></div>
    </div>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Views über Zeit</span></div><div class="chart-wrapper" style="height:220px"><canvas id="youtube-views-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Top Videos</span></div><div class="chart-wrapper" style="height:220px"><canvas id="youtube-top-videos-chart"></canvas></div></div>
    </div>
  </section>

  <section id="tab-tiktok" class="tab-content">
    <h2 class="section-title" id="tiktok-title"><span class="title-icon">🎵</span> TikTok</h2>
    <p class="section-subtitle">Kanal-Performance</p>
    <div class="kpi-grid cols-4 channel-tiktok">
      <div class="kpi-card" data-kpi="tiktok-views"><div class="kpi-card-header"><span class="kpi-card-label">VIEWS</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="tiktok-follower"><div class="kpi-card-header"><span class="kpi-card-label">FOLLOWER</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="tiktok-engagementRate"><div class="kpi-card-header"><span class="kpi-card-label">ENGAGEMENT RATE</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="tiktok-likes"><div class="kpi-card-header"><span class="kpi-card-label">LIKES</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
    </div>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Video-Performance (Views)</span></div><div class="chart-wrapper" style="height:220px"><canvas id="tiktok-performance-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Follower-Wachstum</span></div><div class="chart-wrapper" style="height:220px"><canvas id="tiktok-growth-chart"></canvas></div></div>
    </div>
  </section>

  <section id="tab-linkedin" class="tab-content">
    <h2 class="section-title" id="linkedin-title"><span class="title-icon">💼</span> LinkedIn</h2>
    <p class="section-subtitle">Unternehmensseite Performance</p>
    <div class="kpi-grid cols-4 channel-linkedin">
      <div class="kpi-card" data-kpi="linkedin-impressionen"><div class="kpi-card-header"><span class="kpi-card-label">IMPRESSIONEN</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="linkedin-follower"><div class="kpi-card-header"><span class="kpi-card-label">FOLLOWER</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="linkedin-engagement"><div class="kpi-card-header"><span class="kpi-card-label">ENGAGEMENT</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="linkedin-klicks"><div class="kpi-card-header"><span class="kpi-card-label">KLICKS</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
    </div>
    <div class="charts-grid">
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Top Posts (Impressionen)</span></div><div class="chart-wrapper" style="height:220px"><canvas id="linkedin-impressions-chart"></canvas></div></div>
      <div class="chart-card"><div class="chart-card-header"><span class="chart-card-title">Follower-Wachstum</span></div><div class="chart-wrapper" style="height:220px"><canvas id="linkedin-follower-chart"></canvas></div></div>
    </div>
  </section>

  <section id="tab-mailchimp" class="tab-content">
    <h2 class="section-title" id="mailchimp-title"><span class="title-icon">📧</span> Mailchimp</h2>
    <p class="section-subtitle">E-Mail Marketing Performance</p>
    <div class="kpi-grid cols-4 channel-mailchimp">
      <div class="kpi-card" data-kpi="mailchimp-openRate"><div class="kpi-card-header"><span class="kpi-card-label">OPEN RATE</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="mailchimp-clickRate"><div class="kpi-card-header"><span class="kpi-card-label">CLICK RATE</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="mailchimp-subscribers"><div class="kpi-card-header"><span class="kpi-card-label">ABONNENTEN</span><span class="kpi-trend"></span></div><div class="kpi-value">—</div></div>
      <div class="kpi-card" data-kpi="mailchimp-campaigns"><div class="kpi-card-header"><span class="kpi-card-label">KAMPAGNEN</span></div><div class="kpi-value">—</div></div>
    </div>
    <div class="charts-grid">
