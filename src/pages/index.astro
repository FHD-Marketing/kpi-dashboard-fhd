<script>
  import { initTabNavigation } from '../scripts/tab-navigation.js';
  import { initMonthSelector, refreshMonthButtons, activateLatestMonth } from '../scripts/month-selector.js';
  import { initCharts } from '../scripts/charts.js';
  import { initCampaignToggle } from '../scripts/campaign-toggle.js';
  import { initKpiAnimations } from '../scripts/kpi-animations.js';
  import { fetchMonths, fetchLastUpdated } from '../scripts/data.js';
  import { initInfomaterial } from '../scripts/infomaterial.js';
  import { initContractOverview } from '../scripts/contract-overview.js';
  import { initStudycheck } from '../scripts/studycheck.js';

  document.addEventListener('DOMContentLoaded', async () => {
    initTabNavigation();
    initMonthSelector();
    initCampaignToggle();
    initKpiAnimations();
    initInfomaterial();
    initContractOverview();
    initStudycheck();

    const loadingEl = document.getElementById('loading-state');

    try {
      await Promise.all([fetchMonths(), fetchLastUpdated()]);
      if (loadingEl) loadingEl.classList.remove('active');
      refreshMonthButtons();
      activateLatestMonth();
      setTimeout(() => { initCharts(); }, 200);
    } catch (err: unknown) {
      console.error('Failed to load dashboard data:', err);
      if (loadingEl) loadingEl.classList.remove('active');
      refreshMonthButtons();
      activateLatestMonth();
      setTimeout(() => { initCharts(); }, 200);
    }
  });
</script>
